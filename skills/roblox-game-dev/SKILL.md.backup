```bash
#!/bin/bash
# pre-release-checklist.sh

checklist=(
  "版本号更新"
  "更新日志编写"
  "商店页面更新"
  "社交媒体预告"
  "社区公告准备"
  "客服FAQ更新"
  "数据监控配置"
  "回滚方案准备"
)

for item in "${checklist[@]}"; do
  read -p "✅ 完成: $item? (y/n): " answer
  if [[ $answer != "y" ]]; then
    echo "⚠️  请先完成: $item"
  fi
done
```

